{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist/build",
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@schemas/*": ["./src/schemas/*"],
      "@catalog/*": ["./src/catalog/*"],
      "@generators/*": ["./src/generators/*"],
      "@mappers/*": ["./src/mappers/*"],
      "@install/*": ["./src/install/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
